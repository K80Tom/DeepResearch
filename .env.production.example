APP_ENV=production
HOST=0.0.0.0
PORT=8000
CORS_ALLOW_ORIGINS=https://your-domain.com

DASHSCOPE_API_KEY=replace_with_your_dashscope_key
MODEL=qwen-plus
BOCHA_API_KEY=replace_with_your_bocha_key

THREAD_ID=default
USER_ID=default_user
TENANT_ID=default_tenant
MAX_ITERATIONS=3

ENABLE_MEMORY=true
CHECKPOINTER_BACKEND=postgres
SHORT_TERM_BACKEND=postgres
LONG_TERM_BACKEND=postgres
LONG_TERM_SCOPE=user
SAVE_CONVERSATION_TASK=false
SHORT_TERM_TTL_SECONDS=604800
SHORT_TERM_MAX_MESSAGES=30
SHORT_TERM_SUMMARY_THRESHOLD=20
MEMORY_TOP_K=6

POSTGRES_USER=root
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_DB=postgres
POSTGRES_DSN=postgresql://root:change_this_postgres_password@postgres:5432/postgres

ENABLE_MILVUS=true
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_COLLECTION=mult_agent_memory

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_this_minio_password

HTTP_PORT=80
ATTU_PORT=8001
NO_COLOR=
