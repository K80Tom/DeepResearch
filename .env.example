DASHSCOPE_API_KEY=replace_with_your_dashscope_key
MODEL=qwen-plus

# Multi-tenant and conversation defaults
THREAD_ID=default
USER_ID=default_user
TENANT_ID=default_tenant
MAX_ITERATIONS=3

# Memory and retrieval
ENABLE_MEMORY=true
ENABLE_MILVUS=true
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=mult_agent_memory
MEMORY_TOP_K=6

# External search
BOCHA_API_KEY=replace_with_your_bocha_key

# Storage
POSTGRES_DSN=postgresql://root:123456@127.0.0.1:5432/postgres
REDIS_URL=redis://:123456@127.0.0.1:6379

# Auth
AUTH_TOKEN_TTL_HOURS=168

# Recommended stable backend choices
CHECKPOINTER_BACKEND=postgres
SHORT_TERM_BACKEND=postgres
SHORT_TERM_PERSIST_BACKEND=postgres
LONG_TERM_BACKEND=postgres

SHORT_TERM_TTL_SECONDS=604800
SHORT_TERM_MAX_MESSAGES=30
SHORT_TERM_SUMMARY_THRESHOLD=20
LONG_TERM_SCOPE=user
SAVE_CONVERSATION_TASK=false

NO_COLOR=
WORKSPACE_DIR=/workspace
